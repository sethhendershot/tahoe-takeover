<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Check In Day</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-clipboard-check"></i> Check In Day Meal Logging</h1>
      </div>
      <div class="card-body">
        <% let selectedDate = locals.selectedDate || new Date().toISOString().split('T')[0]; %>
        <% let dayPlan = locals.dayPlan; %>
        <% let meals = locals.meals || []; %>
        <form action="/check-in-day" method="GET" class="mb-3">
          <label for="date" class="form-label">Select Date</label>
          <input type="date" class="form-control" id="date" name="date" value="<%= selectedDate %>" onchange="this.form.submit()">
        </form>
        <form action="/check-in-day" method="POST">
          <input type="hidden" name="date" value="<%= selectedDate %>">
          <% for (let i = 1; i <= 6; i++) { %>
            <div class="mb-4 border p-3 rounded">
              <h5>Meal <%= i %></h5>
              <div class="row">
                <div class="col-md-4">
                  <label class="form-label">Protein (g)</label>
                  <input type="number" step="0.1" class="form-control" name="protein<%= i %>" value="<%= dayPlan && dayPlan.meals[i-1] ? dayPlan.meals[i-1].protein.amount : '' %>">
                  <select class="form-select mt-1" name="proteinMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.protein > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" <%= dayPlan && dayPlan.meals[i-1] && dayPlan.meals[i-1].protein.mealId == meal.id ? 'selected' : '' %>><%= meal.title %> (P: <%= meal.protein %>g)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Carbs (g)</label>
                  <input type="number" step="0.1" class="form-control" name="carbs<%= i %>" value="<%= dayPlan && dayPlan.meals[i-1] ? dayPlan.meals[i-1].carbs.amount : '' %>">
                  <select class="form-select mt-1" name="carbsMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.carb > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" <%= dayPlan && dayPlan.meals[i-1] && dayPlan.meals[i-1].carbs.mealId == meal.id ? 'selected' : '' %>><%= meal.title %> (C: <%= meal.carb %>g)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Fats (g)</label>
                  <input type="number" step="0.1" class="form-control" name="fats<%= i %>" value="<%= dayPlan && dayPlan.meals[i-1] ? dayPlan.meals[i-1].fats.amount : '' %>">
                  <select class="form-select mt-1" name="fatsMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.fats > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" <%= dayPlan && dayPlan.meals[i-1] && dayPlan.meals[i-1].fats.mealId == meal.id ? 'selected' : '' %>><%= meal.title %> (F: <%= meal.fats %>g)</option>
                    <% }); %>
                  </select>
                </div>
              </div>
            </div>
          <% } %>
          <button type="submit" class="btn btn-primary">Save Check In Day</button>
        </form>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>