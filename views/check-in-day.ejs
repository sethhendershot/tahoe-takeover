<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Check In Day</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <style>
    h1 { font-family: 'Montserrat', sans-serif; }
  </style>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
    <div class="container-fluid">
      <a class="navbar-brand" href="/"><i class="fas fa-home"></i> Meal Planning</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/meals">View All Meals</a>
        <a class="nav-link" href="/day-plans">View Day Plans</a>
        <form class="d-inline" action="/logout" method="POST">
          <button class="btn btn-link nav-link" type="submit">Logout</button>
        </form>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-clipboard-check"></i> Check In Day Meal Logging</h1>
        <a href="/" class="btn btn-secondary">Back to Home</a>
      </div>
      <div class="card-body">
        <form action="/check-in-day" method="POST">
          <input type="hidden" name="date" value="<%= new Date().toISOString().split('T')[0] %>">
          <% for (let i = 1; i <= 6; i++) { %>
            <div class="mb-4 border p-3 rounded">
              <h5>Meal <%= i %></h5>
              <div class="row">
                <div class="col-md-4">
                  <label class="form-label">Protein (g)</label>
                  <input type="number" step="0.1" class="form-control" name="protein<%= i %>" value="">
                  <select class="form-select mt-1" name="proteinMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.protein > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>"><%= meal.title %> (P: <%= meal.protein %>g)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Carbs (g)</label>
                  <input type="number" step="0.1" class="form-control" name="carbs<%= i %>" value="">
                  <select class="form-select mt-1" name="carbsMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.carb > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>"><%= meal.title %> (C: <%= meal.carb %>g)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Fats (g)</label>
                  <input type="number" step="0.1" class="form-control" name="fats<%= i %>" value="">
                  <select class="form-select mt-1" name="fatsMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.fats > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>"><%= meal.title %> (F: <%= meal.fats %>g)</option>
                    <% }); %>
                  </select>
                </div>
              </div>
            </div>
          <% } %>
          <button type="submit" class="btn btn-primary">Save Check In Day</button>
        </form>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>