<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Not Training Day</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .logged { background-color: #d4edda !important; }
  </style>
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-bed"></i> Not Training Day Meal Planning</h1>
      </div>
      <div class="card-body">
        <% let selectedDate = locals.selectedDate || new Date().toISOString().split('T')[0]; %>
        <% let meals = locals.meals || []; %>
        <% let existingDayType = locals.existingDayType; %>
        <% let isEditable = !existingDayType || existingDayType === 'not-training'; %>
        <form action="/not-training-day" method="GET" class="mb-3">
          <label for="date" class="form-label">Select Date</label>
          <input type="date" class="form-control" id="date" name="date" value="<%= selectedDate %>" onchange="this.form.submit()">
        </form>
        <% if (existingDayType === 'training') { %>
          <div class="alert alert-warning">
            <strong>This day is saved as a Training Day.</strong> You can convert it to a Not-Training Day to enable editing.
            <button id="convertBtn" class="btn btn-primary btn-sm ms-2">Convert to Not-Training Day</button>
          </div>
        <% } %>
        <% for (let i = 1; i <= 5; i++) { %>
          <form class="meal-form" data-meal="<%= i %>">
            <input type="hidden" name="date" value="<%= selectedDate %>">
            <input type="hidden" name="meal" value="<%= i %>">
            <input type="hidden" name="action" value="log" id="action<%= i %>">
            <div class="mb-4 border p-3 rounded" id="mealDiv<%= i %>">
              <h5 id="mealHeader<%= i %>">Meal <%= i %> <span class="badge" id="status<%= i %>">Not Logged</span></h5>
              <% const mealGuide = (locals.guide || []).find(m => m.meal === i); %>
              <div class="row">
                <div class="col-md-4">
                  <label class="form-label">Protein (g)</label>
                  <input type="number" step="1" class="form-control" id="protein<%= i %>" name="protein" value="<%= mealGuide ? mealGuide.protein : '' %>" <%= isEditable ? '' : 'disabled' %>>
                  <span class="guidance text-muted small">Suggested: <%= mealGuide ? mealGuide.protein + 'g' : 'N/A' %></span>
                  <select class="form-select mt-1" id="proteinMeal<%= i %>" name="proteinMealId" <%= isEditable ? '' : 'disabled' %>>
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.protein > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" data-protein="<%= meal.protein %>"><%= meal.title %> (P: <%= meal.protein %>g)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Carbs (g)</label>
                  <input type="number" step="1" class="form-control" id="carbs<%= i %>" name="carbs" value="<%= mealGuide ? mealGuide.carb : '' %>" <%= isEditable ? '' : 'disabled' %>>
                  <span class="guidance text-muted small">Suggested: <%= mealGuide ? mealGuide.carb + 'g' : 'N/A' %></span>
                  <select class="form-select mt-1" id="carbsMeal<%= i %>" name="carbsMealId" <%= isEditable ? '' : 'disabled' %>>
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.carb > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" data-carbs="<%= meal.carb %>"><%= meal.title %> (C: <%= meal.carb %>g)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Fats (g)</label>
                  <input type="number" step="1" class="form-control" id="fats<%= i %>" name="fats" value="<%= mealGuide ? mealGuide.fats : '' %>" <%= isEditable ? '' : 'disabled' %>>
                  <span class="guidance text-muted small">Suggested: <%= mealGuide ? mealGuide.fats + 'g' : 'N/A' %></span>
                  <select class="form-select mt-1" id="fatsMeal<%= i %>" name="fatsMealId" <%= isEditable ? '' : 'disabled' %>>
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.fats > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" data-fats="<%= meal.fats %>"><%= meal.title %> (F: <%= meal.fats %>g)</option>
                    <% }); %>
                  </select>
                </div>
              </div>
              <% if (isEditable) { %>
                <button type="submit" class="btn btn-primary mt-2" id="logBtn<%= i %>">Log Meal</button>
              <% } %>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    var guide = <%- JSON.stringify(locals.guide || []) %>;
  </script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const selectedDate = '<%= selectedDate %>';
      loadMeals();

      function loadMeals() {
        fetch(`/load-meals?date=${selectedDate}`)
          .then(res => res.json())
          .then(data => {
            for (let i = 1; i <= 5; i++) {
              const mealData = data[i] || {};
              let proteinVal = mealData.protein || '';
              let carbsVal = mealData.carbs || '';
              let fatsVal = mealData.fats || '';
              if (proteinVal === '') {
                const g = guide.find(m => m.meal == i);
                if (g && g.protein) proteinVal = g.protein;
              }
              if (carbsVal === '') {
                const g = guide.find(m => m.meal == i);
                if (g && g.carb) carbsVal = g.carb;
              }
              if (fatsVal === '') {
                const g = guide.find(m => m.meal == i);
                if (g && g.fats) fatsVal = g.fats;
              }
              document.getElementById(`protein${i}`).value = proteinVal;
              document.getElementById(`carbs${i}`).value = carbsVal;
              document.getElementById(`fats${i}`).value = fatsVal;
              document.getElementById(`proteinMeal${i}`).value = mealData.proteinMealId || '';
              document.getElementById(`carbsMeal${i}`).value = mealData.carbsMealId || '';
              document.getElementById(`fatsMeal${i}`).value = mealData.fatsMealId || '';
              updateStatus(i, mealData);
              filterSelect('protein', i);
              filterSelect('carbs', i);
              filterSelect('fats', i);
            }
          });
      }

      function updateStatus(mealNum, mealData) {
        const isLogged = (mealData.protein > 0 || mealData.carbs > 0 || mealData.fats > 0);
        const statusEl = document.getElementById(`status${mealNum}`);
        const btnEl = document.getElementById(`logBtn${mealNum}`);
        const actionEl = document.getElementById(`action${mealNum}`);
        const divEl = document.getElementById(`mealDiv${mealNum}`);
        if (isLogged) {
          statusEl.textContent = 'Logged';
          statusEl.className = 'badge bg-success';
          btnEl.textContent = 'Un-log Meal';
          btnEl.className = 'btn btn-danger mt-2';
          actionEl.value = 'unlog';
          divEl.classList.add('logged');
        } else {
          statusEl.textContent = 'Not Logged';
          statusEl.className = 'badge bg-secondary';
          btnEl.textContent = 'Log Meal';
          btnEl.className = 'btn btn-primary mt-2';
          actionEl.value = 'log';
          divEl.classList.remove('logged');
        }
      }

      // Form submit
      document.querySelectorAll('.meal-form').forEach(form => {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          const data = Object.fromEntries(new FormData(this));
          fetch('/not-training-day', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          }).then(res => res.json()).then(() => {
            loadMeals();
          });
        });
      });

      // On select change, update input
      for (let i = 1; i <= 5; i++) {
        ['protein', 'carbs', 'fats'].forEach(macro => {
          document.getElementById(`${macro}Meal${i}`).addEventListener('change', function() {
            const mealId = this.value;
            if (mealId) {
              const selectedOption = this.options[this.selectedIndex];
              const mealValue = selectedOption.dataset[macro];
              document.getElementById(`${macro}${i}`).value = mealValue;
            }
          });
        });
      }

      // Convert day type
      const convertBtn = document.getElementById('convertBtn');
      if (convertBtn) {
        convertBtn.addEventListener('click', function() {
          fetch('/convert-day-type', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ date: selectedDate, newType: 'not-training' })
          }).then(res => res.json()).then(() => {
            location.reload();
          });
        });
      }

    });

    function filterSelect(macro, mealNum) {
      const input = document.getElementById(`${macro}${mealNum}`);
      const select = document.getElementById(`${macro}Meal${mealNum}`);
      const amount = input.value;
      const options = select.querySelectorAll('option');
      options.forEach(option => {
        if (option.value === '') return;
        const mealValue = parseFloat(option.dataset[macro]);
        option.style.display = (amount === '' || mealValue <= parseFloat(amount)) ? '' : 'none';
      });
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>