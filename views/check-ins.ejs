<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Check Ins</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h1><i class="fas fa-clipboard-check"></i> Check Ins</h1>
        <a href="/create-check-in" class="btn btn-primary">Add New Check In</a>
      </div>
      <div class="card-body">
        <table id="checkInsTable" class="table table-striped">
          <thead>
            <tr>
              <th>Date</th>
              <th>Weight (lbs)</th>
              <th>Hips (in)</th>
              <th>Waist (in)</th>
              <th>Chest (in)</th>
              <th>Arms (in)</th>
              <th>Thighs (in)</th>
              <th>Pictures</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% Object.keys(checkInsData).forEach(date => { %>
              <% const checkIn = checkInsData[date]; %>
              <tr>
                <td><%= date %></td>
                <td><%= checkIn.weight %></td>
                <td><%= checkIn.measurements.hips %></td>
                <td><%= checkIn.measurements.waist %></td>
                <td><%= checkIn.measurements.chest %></td>
                <td><%= checkIn.measurements.arms %></td>
                <td><%= checkIn.measurements.thighs %></td>
                <td>
                  <% checkIn.pictures.forEach(pic => { %>
                    <img src="/uploads/<%= pic %>" alt="Check-in picture" style="width: 50px; height: 50px; margin-right: 5px; cursor: pointer;" onclick="viewImage('/uploads/<%= pic %>')">
                  <% }); %>
                </td>
                <td><button type="button" class="btn btn-primary btn-sm me-2" onclick="viewCheckIn('<%= date %>')">View Check In</button><button type="button" class="btn btn-danger btn-sm" onclick="deleteCheckIn('<%= date %>')">Delete</button></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Image View Modal -->
  <div class="modal fade" id="imageViewModal" tabindex="-1" aria-labelledby="imageViewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="imageViewModalLabel">Check-in Picture</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-center">
          <img id="modalImage" src="" alt="Check-in picture" style="max-width: 100%; max-height: 70vh;">
        </div>
      </div>
    </div>
  </div>

  <!-- Check In View Modal -->
  <div class="modal fade" id="checkInViewModal" tabindex="-1" aria-labelledby="checkInViewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="checkInViewModalLabel">Check In Details - <span id="modalDate"></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6">
              <h6>Weight</h6>
              <p id="modalWeight"></p>
            </div>
            <div class="col-md-6">
              <h6>User</h6>
              <p id="modalUser"></p>
            </div>
          </div>
          <h6>Measurements</h6>
          <div class="row">
            <div class="col-md-4">
              <strong>Hips:</strong> <span id="modalHips"></span> in
            </div>
            <div class="col-md-4">
              <strong>Waist:</strong> <span id="modalWaist"></span> in
            </div>
            <div class="col-md-4">
              <strong>Chest:</strong> <span id="modalChest"></span> in
            </div>
            <div class="col-md-4">
              <strong>Arms:</strong> <span id="modalArms"></span> in
            </div>
            <div class="col-md-4">
              <strong>Thighs:</strong> <span id="modalThighs"></span> in
            </div>
          </div>
          <h6>Pictures</h6>
          <div id="modalPictures" class="d-flex flex-wrap"></div>
        </div>
      </div>
    </div>
  </div>
  <script>
    var checkInsData = <%- JSON.stringify(checkInsData) %>;
  </script>
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
  <script>
    $(document).ready(function() {
      $('#checkInsTable').DataTable();
    });

    function viewImage(src) {
      document.getElementById('modalImage').src = src;
      var modal = new bootstrap.Modal(document.getElementById('imageViewModal'));
      modal.show();
    }

    function viewCheckIn(date) {
      const checkIn = checkInsData[date];
      if (!checkIn) return;

      document.getElementById('modalDate').textContent = date;
      document.getElementById('modalWeight').textContent = checkIn.weight + ' lbs';
      document.getElementById('modalUser').textContent = checkIn.user;
      document.getElementById('modalHips').textContent = checkIn.measurements.hips;
      document.getElementById('modalWaist').textContent = checkIn.measurements.waist;
      document.getElementById('modalChest').textContent = checkIn.measurements.chest;
      document.getElementById('modalArms').textContent = checkIn.measurements.arms;
      document.getElementById('modalThighs').textContent = checkIn.measurements.thighs;

      const picturesDiv = document.getElementById('modalPictures');
      picturesDiv.innerHTML = '';
      checkIn.pictures.forEach(pic => {
        const img = document.createElement('img');
        img.src = '/uploads/' + pic;
        img.alt = 'Check-in picture';
        img.style.width = '100px';
        img.style.height = '100px';
        img.style.margin = '5px';
        img.style.cursor = 'pointer';
        img.onclick = () => viewImage('/uploads/' + pic);
        picturesDiv.appendChild(img);
      });

      var modal = new bootstrap.Modal(document.getElementById('checkInViewModal'));
      modal.show();
    }

    function deleteCheckIn(date) {
      if (confirm('Are you sure you want to delete this check-in? This action cannot be undone.')) {
        fetch('/delete-check-in', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: 'date=' + encodeURIComponent(date)
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            location.reload();
          } else {
            alert('Error deleting check-in: ' + (data.error || 'Unknown error'));
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('Error deleting check-in');
        });
      }
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>