<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Check Ins</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h1><i class="fas fa-clipboard-check"></i> Check Ins</h1>
        <div>
          <button type="button" class="btn btn-info me-2" id="compareBtn" onclick="showCompare()">Compare Pictures</button>
          <a href="/create-check-in" class="btn btn-primary">Add New Check In</a>
        </div>
      </div>
      <div class="card-body">
        <table id="checkInsTable" class="table table-striped">
          <thead>
            <tr>
              <th>Date</th>
              <th>Weight (lbs)</th>
              <th>Waist (in)</th>
              <th>Glutes (in)</th>
              <th>Pictures</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% Object.keys(checkInsData).forEach(date => { %>
              <% const checkIn = checkInsData[date]; %>
              <tr>
                <td><%= date %></td>
                <td><%= checkIn.weight %></td>
                <td><%= checkIn.measurements.waist %></td>
                <td><%= checkIn.measurements.hips %></td>
                <td>
                  <% checkIn.pictures.forEach((pic, index) => { %>
                    <div class="d-inline-block position-relative me-2 mb-2">
                      <input type="checkbox" class="picture-checkbox" data-src="/uploads/<%= pic %>" data-date="<%= date %>" style="position: absolute; top: 2px; left: 2px; z-index: 10;">
                      <img src="/uploads/<%= pic %>" alt="Check-in picture" style="width: 50px; height: 50px; cursor: pointer;" onclick="viewImage('/uploads/<%= pic %>', '<%= date %>', <%= index %>)">
                    </div>
                  <% }); %>
                </td>
                <td><button type="button" class="btn btn-warning btn-sm me-2" onclick="editCheckIn('<%= date %>')">Edit</button><button type="button" class="btn btn-primary btn-sm me-2" onclick="viewCheckIn('<%= date %>')">View Check In</button><button type="button" class="btn btn-danger btn-sm" onclick="deleteCheckIn('<%= date %>')">Delete</button></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Image View Modal -->
  <div class="modal fade" id="imageViewModal" tabindex="-1" aria-labelledby="imageViewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="imageViewModalLabel">Check-in Picture</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body text-center">
          <img id="modalImage" src="" alt="Check-in picture" style="max-width: 100%; max-height: 70vh;">
          <div class="mt-3">
            <button type="button" class="btn btn-outline-secondary me-2" id="moveLeftBtn" onclick="reorderPicture('left')" disabled>
              <i class="fas fa-arrow-left"></i> Move Left
            </button>
            <button type="button" class="btn btn-secondary me-2" onclick="rotateImage('left')">
              <i class="fas fa-undo"></i> Rotate Left
            </button>
            <button type="button" class="btn btn-secondary me-2" onclick="rotateImage('right')">
              <i class="fas fa-redo"></i> Rotate Right
            </button>
            <button type="button" class="btn btn-outline-secondary" id="moveRightBtn" onclick="reorderPicture('right')" disabled>
              <i class="fas fa-arrow-right"></i> Move Right
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Check In View Modal -->
  <div class="modal fade" id="checkInViewModal" tabindex="-1" aria-labelledby="checkInViewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="checkInViewModalLabel">Check In Details - <span id="modalDate"></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6">
              <h6>Weight</h6>
              <p id="modalWeight"></p>
            </div>
            <div class="col-md-6">
              <h6>User</h6>
              <p id="modalUser"></p>
            </div>
          </div>
          <h6>Measurements</h6>
          <div class="row">
            <div class="col-md-6">
              <strong>Waist:</strong> <span id="modalWaist"></span> in
            </div>
            <div class="col-md-6">
              <strong>Glutes:</strong> <span id="modalHips"></span> in
            </div>
          </div>
          <h6>Pictures</h6>
          <div id="modalPictures" class="d-flex flex-wrap"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Check In Modal -->
  <div class="modal fade" id="editCheckInModal" tabindex="-1" aria-labelledby="editCheckInModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="editCheckInModalLabel">Edit Check In</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="editCheckInForm" enctype="multipart/form-data">
            <div class="mb-3">
              <label for="editDate" class="form-label">Date</label>
              <input type="date" class="form-control" id="editDate" name="date" required>
            </div>
            <div class="mb-3">
              <label for="editWeight" class="form-label">Weight (lbs)</label>
              <input type="number" step="0.1" class="form-control" id="editWeight" name="weight" required>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label for="editWaist" class="form-label">Waist (in)</label>
                <input type="number" step="0.1" class="form-control" id="editWaist" name="waist" required>
              </div>
              <div class="col-md-6 mb-3">
                <label for="editHips" class="form-label">Glutes (in)</label>
                <input type="number" step="0.1" class="form-control" id="editHips" name="hips" required>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Current Pictures</label>
              <div id="currentPictures" class="d-flex flex-wrap mb-3"></div>
              <label for="editPictures" class="form-label">Add More Pictures (optional)</label>
              <input type="file" class="form-control" id="editPictures" name="pictures" multiple accept="image/*">
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" onclick="saveCheckInEdit()">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Compare Pictures Modal -->
  <div class="modal fade" id="compareModal" tabindex="-1" aria-labelledby="compareModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="compareModalLabel">Compare Pictures</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div id="compareContainer" class="d-flex flex-wrap justify-content-center gap-1">
            <!-- Pictures will be added here dynamically -->
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
  <script>
    var checkInsData = <%- JSON.stringify(checkInsData) %>;
    let compareModalInstance = null;

    $(document).ready(function() {
      $('#checkInsTable').DataTable();
    });

    function viewImage(src, date, index) {
      document.getElementById('modalImage').src = src;
      // Store the filename, date, and index for rotation and reordering
      window.currentImageFilename = src.split('/').pop();
      window.currentImageDate = date;
      window.currentImageIndex = index;

      // Update move button states
      const checkIn = checkInsData[date];
      const moveLeftBtn = document.getElementById('moveLeftBtn');
      const moveRightBtn = document.getElementById('moveRightBtn');

      if (checkIn && checkIn.pictures) {
        moveLeftBtn.disabled = index <= 0;
        moveRightBtn.disabled = index >= checkIn.pictures.length - 1;
      }

      var modal = new bootstrap.Modal(document.getElementById('imageViewModal'));
      modal.show();
    }

    function reorderPicture(direction) {
      if (!window.currentImageFilename || !window.currentImageDate) return;

      fetch('/reorder-picture', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'date=' + encodeURIComponent(window.currentImageDate) + '&filename=' + encodeURIComponent(window.currentImageFilename) + '&direction=' + direction
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Update the checkInsData with new order
          checkInsData[window.currentImageDate].pictures = data.newOrder;

          // Update current index
          window.currentImageIndex = data.newOrder.indexOf(window.currentImageFilename);

          // Update move button states
          const moveLeftBtn = document.getElementById('moveLeftBtn');
          const moveRightBtn = document.getElementById('moveRightBtn');
          moveLeftBtn.disabled = window.currentImageIndex <= 0;
          moveRightBtn.disabled = window.currentImageIndex >= data.newOrder.length - 1;

          // Refresh the page to show updated order
          location.reload();
        } else {
          alert('Error reordering picture: ' + (data.error || 'Unknown error'));
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error reordering picture');
      });
    }

    function rotateImage(direction) {
      if (!window.currentImageFilename) return;

      fetch('/rotate-image', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'filename=' + encodeURIComponent(window.currentImageFilename) + '&direction=' + direction
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Reload the image to show the rotation
          const img = document.getElementById('modalImage');
          img.src = img.src + '?t=' + Date.now(); // Add timestamp to force reload
        } else {
          alert('Error rotating image: ' + (data.error || 'Unknown error'));
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error rotating image');
      });
    }

    function viewCheckIn(date) {
      const checkIn = checkInsData[date];
      if (!checkIn) return;

      document.getElementById('modalDate').textContent = date;
      document.getElementById('modalWeight').textContent = checkIn.weight + ' lbs';
      document.getElementById('modalUser').textContent = checkIn.user;
      document.getElementById('modalWaist').textContent = checkIn.measurements.waist;
      document.getElementById('modalHips').textContent = checkIn.measurements.hips;

      const picturesDiv = document.getElementById('modalPictures');
      picturesDiv.innerHTML = '';
      checkIn.pictures.forEach((pic, index) => {
        const container = document.createElement('div');
        container.style.position = 'relative';
        container.style.display = 'inline-block';
        container.style.margin = '5px';

        const img = document.createElement('img');
        img.src = '/uploads/' + pic;
        img.alt = 'Check-in picture';
        img.style.width = '100px';
        img.style.height = '100px';
        img.style.cursor = 'pointer';
        img.onclick = () => viewImage('/uploads/' + pic, date, index);

        const deleteBtn = document.createElement('button');
        deleteBtn.innerHTML = '×';
        deleteBtn.style.position = 'absolute';
        deleteBtn.style.top = '-5px';
        deleteBtn.style.right = '-5px';
        deleteBtn.style.background = 'red';
        deleteBtn.style.color = 'white';
        deleteBtn.style.border = 'none';
        deleteBtn.style.borderRadius = '50%';
        deleteBtn.style.width = '20px';
        deleteBtn.style.height = '20px';
        deleteBtn.style.fontSize = '14px';
        deleteBtn.style.cursor = 'pointer';
        deleteBtn.style.display = 'flex';
        deleteBtn.style.alignItems = 'center';
        deleteBtn.style.justifyContent = 'center';
        deleteBtn.title = 'Delete picture';
        deleteBtn.onclick = (e) => {
          e.stopPropagation(); // Prevent triggering the image click
          deletePicture(date, pic);
        };

        container.appendChild(img);
        container.appendChild(deleteBtn);
        picturesDiv.appendChild(container);
      });

      var modal = new bootstrap.Modal(document.getElementById('checkInViewModal'));
      modal.show();
    }

    function editCheckIn(date) {
      const checkIn = checkInsData[date];
      if (!checkIn) return;

      // Store the original date for updating
      window.editingCheckInDate = date;

      // Populate form fields
      document.getElementById('editDate').value = date;
      document.getElementById('editWeight').value = checkIn.weight;
      document.getElementById('editWaist').value = checkIn.measurements.waist;
      document.getElementById('editHips').value = checkIn.measurements.hips;

      // Show current pictures
      const currentPicturesDiv = document.getElementById('currentPictures');
      currentPicturesDiv.innerHTML = '';
      checkIn.pictures.forEach((pic, index) => {
        const img = document.createElement('img');
        img.src = '/uploads/' + pic;
        img.alt = 'Check-in picture';
        img.style.width = '80px';
        img.style.height = '80px';
        img.style.margin = '5px';
        img.style.border = '1px solid #ddd';
        currentPicturesDiv.appendChild(img);
      });

      var modal = new bootstrap.Modal(document.getElementById('editCheckInModal'));
      modal.show();
    }

    function saveCheckInEdit() {
      const form = document.getElementById('editCheckInForm');
      const formData = new FormData(form);

      // Add the original date for updating
      formData.append('originalDate', window.editingCheckInDate);

      fetch('/update-check-in', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Close modal and reload page
          const modal = bootstrap.Modal.getInstance(document.getElementById('editCheckInModal'));
          modal.hide();
          location.reload();
        } else {
          alert('Error updating check-in: ' + (data.error || 'Unknown error'));
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error updating check-in');
      });
    }

    function deleteCheckIn(date) {
      if (!confirm('Are you sure you want to delete this check-in? This action cannot be undone.')) {
        return;
      }

      fetch('/delete-check-in', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'date=' + encodeURIComponent(date)
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          location.reload();
        } else {
          alert('Error deleting check-in: ' + (data.error || 'Unknown error'));
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error deleting check-in');
      });
    }

    function deletePicture(date, filename) {
      if (!confirm('Are you sure you want to delete this picture? This action cannot be undone.')) {
        return;
      }

      fetch('/delete-picture', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: 'date=' + encodeURIComponent(date) + '&filename=' + encodeURIComponent(filename)
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          // Update the local data
          const checkIn = checkInsData[date];
          if (checkIn && checkIn.pictures) {
            checkIn.pictures = checkIn.pictures.filter(pic => pic !== filename);
          }
          // Refresh the current modal view
          viewCheckIn(date);
        } else {
          alert('Error deleting picture: ' + (data.error || 'Unknown error'));
        }
      })
      .catch(error => {
        console.error('Error:', error);
        alert('Error deleting picture');
      });
    }

    // Compare functionality
    let selectedPictures = [];

    function updateCompareButton() {
      const compareBtn = document.getElementById('compareBtn');
      if (selectedPictures.length >= 2 && selectedPictures.length <= 4) {
        compareBtn.style.display = 'inline-block';
      } else {
        compareBtn.style.display = 'none';
      }
    }

    // Add event listeners to checkboxes
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.picture-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
          const src = this.getAttribute('data-src');
          const date = this.getAttribute('data-date');

          if (this.checked) {
            if (selectedPictures.length < 4) {
              selectedPictures.push({ src, date });
            } else {
              this.checked = false;
              alert('You can select a maximum of 4 pictures to compare.');
            }
          } else {
            selectedPictures = selectedPictures.filter(pic => !(pic.src === src && pic.date === date));
          }

          updateCompareButton();
        });
      });

      // Initial check
      updateCompareButton();
    });

    function moveComparePicture(index, direction) {
      if (direction === 'left' && index > 0) {
        [selectedPictures[index], selectedPictures[index-1]] = [selectedPictures[index-1], selectedPictures[index]];
      } else if (direction === 'right' && index < selectedPictures.length - 1) {
        [selectedPictures[index], selectedPictures[index+1]] = [selectedPictures[index+1], selectedPictures[index]];
      }
      showCompare();
    }

    function showCompare() {
      const compareContainer = document.getElementById('compareContainer');
      compareContainer.innerHTML = '';

      selectedPictures.forEach((picture, index) => {
        const imgContainer = document.createElement('div');
        imgContainer.className = 'text-center';
        imgContainer.style.flex = '1';
        imgContainer.style.minWidth = '200px';

        const img = document.createElement('img');
        img.src = picture.src;
        img.alt = 'Comparison picture';
        img.style.maxWidth = '100%';
        img.style.maxHeight = '300px';
        img.style.objectFit = 'contain';
        img.style.border = '1px solid #ddd';
        img.style.borderRadius = '5px';

        const dateLabel = document.createElement('p');
        dateLabel.className = 'mt-2 mb-0 text-muted';
        dateLabel.textContent = 'Date: ' + picture.date;

        const buttonContainer = document.createElement('div');
        buttonContainer.className = 'mt-2';
        const leftBtn = document.createElement('button');
        leftBtn.className = 'btn btn-sm btn-outline-secondary me-1';
        leftBtn.innerHTML = '<i class="fas fa-arrow-left"></i>';
        leftBtn.onclick = () => moveComparePicture(index, 'left');
        const rightBtn = document.createElement('button');
        rightBtn.className = 'btn btn-sm btn-outline-secondary';
        rightBtn.innerHTML = '<i class="fas fa-arrow-right"></i>';
        rightBtn.onclick = () => moveComparePicture(index, 'right');
        buttonContainer.appendChild(leftBtn);
        buttonContainer.appendChild(rightBtn);

        imgContainer.appendChild(img);
        imgContainer.appendChild(dateLabel);
        imgContainer.appendChild(buttonContainer);
        compareContainer.appendChild(imgContainer);
      });

      if (!compareModalInstance) {
        compareModalInstance = new bootstrap.Modal(document.getElementById('compareModal'));
      }
      if (!document.getElementById('compareModal').classList.contains('show')) {
        compareModalInstance.show();
      }
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>