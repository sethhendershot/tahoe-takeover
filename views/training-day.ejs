<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Training Day</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <style>
    h1 { font-family: 'Montserrat', sans-serif; }
  </style>
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-dumbbell"></i> Training Day Meal Planning</h1>
        <a href="/" class="btn btn-secondary">Back to Home</a>
        <a href="/meal-guide" class="btn btn-info">View Meal Guidance</a>
      </div>
      <div class="card-body">
        <% let selectedDate = locals.selectedDate || new Date().toISOString().split('T')[0]; %>
        <% let meals = locals.meals || []; %>
        <form action="/training-day" method="GET" class="mb-3">
          <label for="date" class="form-label">Select Date</label>
          <input type="date" class="form-control" id="date" name="date" value="<%= selectedDate %>" onchange="this.form.submit()">
        </form>
        <button id="toggleGuidance" class="btn btn-outline-primary mb-3">Show Guidance</button>
        <form action="/training-day" method="POST">
          <input type="hidden" name="date" value="<%= selectedDate %>">
          <% for (let i = 1; i <= 6; i++) { %>
            <div class="mb-4 border p-3 rounded">
              <h5>Meal <%= i %></h5>
              <div class="row">
                <div class="col-md-4">
                  <label class="form-label">Protein (g)</label>
                  <input type="number" step="1" class="form-control" id="protein<%= i %>" name="protein<%= i %>" value="">
                  <% const mealGuide = (locals.guide || []).find(m => m.meal === i); %>
                  <span class="guidance text-muted small" style="display:none;">Suggested: <%= mealGuide ? mealGuide.protein + 'g' : 'N/A' %></span>
                  <select class="form-select mt-1" id="proteinMeal<%= i %>" name="proteinMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.protein > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" data-protein="<%= meal.protein %>"><%= meal.title %> (P: <%= meal.protein %>g)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Carbs (g)</label>
                  <input type="number" step="1" class="form-control" id="carbs<%= i %>" name="carbs<%= i %>" value="">
                  <span class="guidance text-muted small" style="display:none;">Suggested: <%= mealGuide ? mealGuide.carb + 'g' : 'N/A' %></span>
                  <select class="form-select mt-1" id="carbsMeal<%= i %>" name="carbsMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.carb > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" data-carbs="<%= meal.carb %>"><%= meal.title %> (C: <%= meal.carb %>g)</option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-md-4">
                  <label class="form-label">Fats (g)</label>
                  <input type="number" step="1" class="form-control" id="fats<%= i %>" name="fats<%= i %>" value="">
                  <span class="guidance text-muted small" style="display:none;">Suggested: <%= mealGuide ? mealGuide.fats + 'g' : 'N/A' %></span>
                  <select class="form-select mt-1" id="fatsMeal<%= i %>" name="fatsMeal<%= i %>">
                    <option value="">Select Meal</option>
                    <% (meals || []).filter(meal => meal.fats > 0).forEach(meal => { %>
                      <option value="<%= meal.id %>" data-fats="<%= meal.fats %>"><%= meal.title %> (F: <%= meal.fats %>g)</option>
                    <% }); %>
                  </select>
                </div>
              </div>
            </div>
          <% } %>
          <button type="submit" class="btn btn-primary">Save Training Day</button>
        </form>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const selectedDate = '<%= selectedDate %>';
      // Load meals for the date
      fetch(`/load-meals?date=${selectedDate}`)
        .then(res => res.json())
        .then(data => {
          for (let i = 1; i <= 6; i++) {
            const mealData = data[i] || {};
            document.getElementById(`protein${i}`).value = mealData.protein || '';
            document.getElementById(`carbs${i}`).value = mealData.carbs || '';
            document.getElementById(`fats${i}`).value = mealData.fats || '';
            document.getElementById(`proteinMeal${i}`).value = mealData.proteinMealId || '';
            document.getElementById(`carbsMeal${i}`).value = mealData.carbsMealId || '';
            document.getElementById(`fatsMeal${i}`).value = mealData.fatsMealId || '';
            // filter selects
            filterSelect('protein', i);
            filterSelect('carbs', i);
            filterSelect('fats', i);
          }
        });
      // On select change, update mealId
      for (let i = 1; i <= 6; i++) {
        ['protein', 'carbs', 'fats'].forEach(macro => {
          document.getElementById(`${macro}Meal${i}`).addEventListener('change', function() {
            const mealId = this.value;
            if (mealId) {
              const selectedOption = this.options[this.selectedIndex];
              const mealValue = selectedOption.dataset[macro];
              document.getElementById(`${macro}${i}`).value = mealValue;
            }
            fetch('/update-meal', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ date: selectedDate, mealNum: i, macro, mealId })
            });
          });
        });
      }
      // On input change, update amount and filter
      for (let i = 1; i <= 6; i++) {
        ['protein', 'carbs', 'fats'].forEach(macro => {
          document.getElementById(`${macro}${i}`).addEventListener('change', function() {
            const amount = this.value;
            fetch('/update-amount', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ date: selectedDate, mealNum: i, macro, amount: parseFloat(amount) || 0 })
            }).then(() => {
              filterSelect(macro, i);
            });
          });
        });
      }

      // Toggle guidance
      document.getElementById('toggleGuidance').addEventListener('click', function() {
        const guidanceElements = document.querySelectorAll('.guidance');
        const isVisible = Array.from(guidanceElements).some(el => el.style.display !== 'none');
        guidanceElements.forEach(el => {
          el.style.display = isVisible ? 'none' : 'inline';
        });
        this.textContent = isVisible ? 'Show Guidance' : 'Hide Guidance';
      });
    });

    function filterSelect(macro, mealNum) {
      const input = document.getElementById(`${macro}${mealNum}`);
      const select = document.getElementById(`${macro}Meal${mealNum}`);
      const amount = input.value;
      const options = select.querySelectorAll('option');
      options.forEach(option => {
        if (option.value === '') return;
        const mealValue = parseFloat(option.dataset[macro]);
        option.style.display = (amount === '' || mealValue <= parseFloat(amount)) ? '' : 'none';
      });
    }
  </script>
</body>
</html>