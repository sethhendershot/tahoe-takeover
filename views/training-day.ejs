<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Training Day</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Meal Planning</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/meals">View All Meals</a>
        <form class="d-inline" action="/logout" method="POST">
          <button class="btn btn-link nav-link" type="submit">Logout</button>
        </form>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1>Training Day Meal Planning</h1>
        <a href="/" class="btn btn-secondary">Back to Home</a>
      </div>
      <div class="card-body">
        <form>
          <% for (let i = 1; i <= 6; i++) { %>
            <div class="mb-3">
              <label for="meal<%= i %>" class="form-label">Meal <%= i %></label>
              <input type="text" class="form-control" id="meal<%= i %>" name="meal<%= i %>" placeholder="Enter meal <%= i %>">
            </div>
          <% } %>
          <button type="submit" class="btn btn-primary">Save Meals</button>
        </form>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>