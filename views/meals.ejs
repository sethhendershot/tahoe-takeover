<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meals</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <style>
    h1 { font-family: 'Montserrat', sans-serif; }
  </style>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
    <div class="container-fluid">
      <a class="navbar-brand" href="/"><i class="fas fa-list"></i> Prep Planner</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/meals">View All Meals</a>
        <form class="d-inline" action="/logout" method="POST">
          <button class="btn btn-link nav-link" type="submit">Logout</button>
        </form>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-utensils"></i> Meals</h1>
        <a href="/" class="btn btn-secondary">Back to Home</a>
      </div>
      <div class="card-body">
        <h2>Add New Meal</h2>
        <form id="addMealForm" action="/meals" method="POST">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" class="form-control" id="title" name="title" required>
          </div>
          <div class="mb-3">
            <label for="protein" class="form-label">Protein (g)</label>
            <input type="number" step="0.1" class="form-control" id="protein" name="protein" required>
          </div>
          <div class="mb-3">
            <label for="carb" class="form-label">Carb (g)</label>
            <input type="number" step="0.1" class="form-control" id="carb" name="carb" required>
          </div>
          <div class="mb-3">
            <label for="fats" class="form-label">Fats (g)</label>
            <input type="number" step="0.1" class="form-control" id="fats" name="fats" required>
          </div>
          <button type="submit" class="btn btn-primary">Add Meal</button>
        </form>
        <hr>
        <h2>All Meals</h2>
        <table id="mealsTable" class="display">
          <thead>
            <tr>
              <th>Title</th>
              <th>Protein (g)</th>
              <th>Carb (g)</th>
              <th>Fats (g)</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% meals.forEach(meal => { %>
              <tr>
                <td><%= meal.title %></td>
                <td><%= meal.protein %></td>
                <td><%= meal.carb %></td>
                <td><%= meal.fats %></td>
                <td>
                <button class="btn btn-sm btn-warning edit-btn" data-id="<%= meal.id %>" data-title="<%= meal.title %>" data-protein="<%= meal.protein %>" data-carb="<%= meal.carb %>" data-fats="<%= meal.fats %>">Edit</button>
                <button class="btn btn-sm btn-danger delete-btn" data-id="<%= meal.id %>">Delete</button>
              </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <!-- Edit Meal Modal -->
  <div class="modal fade" id="editMealModal" tabindex="-1" aria-labelledby="editMealModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="editMealModalLabel">Edit Meal</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="editMealForm" action="/meals" method="POST">
            <input type="hidden" id="editMealId" name="id">
            <div class="mb-3">
              <label for="editTitle" class="form-label">Title</label>
              <input type="text" class="form-control" id="editTitle" name="title" required>
            </div>
            <div class="mb-3">
              <label for="editProtein" class="form-label">Protein (g)</label>
              <input type="number" step="0.1" class="form-control" id="editProtein" name="protein" required>
            </div>
            <div class="mb-3">
              <label for="editCarb" class="form-label">Carb (g)</label>
              <input type="number" step="0.1" class="form-control" id="editCarb" name="carb" required>
            </div>
            <div class="mb-3">
              <label for="editFats" class="form-label">Fats (g)</label>
              <input type="number" step="0.1" class="form-control" id="editFats" name="fats" required>
            </div>
            <button type="submit" class="btn btn-primary" id="saveMeal">Update Meal</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <!-- Toast Notification -->
  <div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="toast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="toast-body"></div>
    </div>
  </div>
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    $(document).ready(function() {
      $('#mealsTable').DataTable({ pageLength: 25 });
      $('#addMealForm').on('submit', function(e) {
        e.preventDefault();
        $.post('/meals', $(this).serialize(), function(response) {
          if (response.success) {
            showToast(response.message, 'success');
            $(this).trigger('reset'); // Clear the form
            // Add new row using DataTable API
            const table = $('#mealsTable').DataTable();
            const meal = response.meal;
            table.row.add([
              meal.title,
              meal.protein,
              meal.carb,
              meal.fats,
              `<button class="btn btn-sm btn-warning edit-btn" data-id="${meal.id}" data-title="${meal.title}" data-protein="${meal.protein}" data-carb="${meal.carb}" data-fats="${meal.fats}">Edit</button> <button class="btn btn-sm btn-danger delete-btn" data-id="${meal.id}">Delete</button>`
            ]).draw();
          } else {
            showToast(response.message, 'danger');
          }
        }.bind(this)).fail(function(xhr) {
          const message = xhr.responseJSON?.message || xhr.statusText;
          showToast('Error: ' + message, 'danger');
        });
      });
      $('#editMealForm').on('submit', function(e) {
        e.preventDefault();
        $.post('/meals', $(this).serialize(), function(response) {
          if (response.success) {
            showToast(response.message, 'success');
            $('#editMealModal').modal('hide');
            // Update the row using DataTable API
            const table = $('#mealsTable').DataTable();
            const meal = response.meal;
            const row = $(`#mealsTable tbody tr`).find(`.edit-btn[data-id="${meal.id}"]`).closest('tr');
            const rowIndex = table.row(row).index();
            table.row(rowIndex).data([
              meal.title,
              meal.protein,
              meal.carb,
              meal.fats,
              `<button class="btn btn-sm btn-warning edit-btn" data-id="${meal.id}" data-title="${meal.title}" data-protein="${meal.protein}" data-carb="${meal.carb}" data-fats="${meal.fats}">Edit</button> <button class="btn btn-sm btn-danger delete-btn" data-id="${meal.id}">Delete</button>`
            ]).draw();
          } else {
            showToast(response.message, 'danger');
          }
        }).fail(function(xhr) {
          const message = xhr.responseJSON?.message || xhr.statusText;
          showToast('Error: ' + message, 'danger');
        });
      });
      $('#mealsTable').on('click', '.edit-btn', function() {
        const id = $(this).data('id');
        const title = $(this).data('title');
        const protein = $(this).data('protein');
        const carb = $(this).data('carb');
        const fats = $(this).data('fats');
        $('#editMealId').val(id);
        $('#editTitle').val(title);
        $('#editProtein').val(protein);
        $('#editCarb').val(carb);
        $('#editFats').val(fats);
        $('#editMealModal').modal('show');
      });
      $('#mealsTable').on('click', '.delete-btn', function() {
        const id = $(this).data('id');
        if (confirm('Are you sure you want to delete this meal?')) {
          $.post('/meals', { id, action: 'delete' }, function(response) {
            if (response.success) {
              showToast(response.message, 'success');
              // Remove the row using DataTable API
              const table = $('#mealsTable').DataTable();
              const row = $(this).closest('tr');
              table.row(row).remove().draw();
            } else {
              showToast(response.message, 'danger');
            }
          }.bind(this)).fail(function(xhr) {
            const message = xhr.responseJSON?.message || xhr.statusText;
            showToast('Error: ' + message, 'danger');
          });
        }
      });
      function updateTable() {
        $.ajax({
          url: '/meals',
          headers: { 'Accept': 'application/json' },
          success: function(meals) {
            const tbody = $('#mealsTable tbody');
            tbody.empty();
            meals.forEach(meal => {
              tbody.append(`
                <tr>
                  <td>${meal.title}</td>
                  <td>${meal.protein}</td>
                  <td>${meal.carb}</td>
                  <td>${meal.fats}</td>
                  <td>
                    <button class="btn btn-sm btn-warning edit-btn" data-id="${meal.id}" data-title="${meal.title}" data-protein="${meal.protein}" data-carb="${meal.carb}" data-fats="${meal.fats}">Edit</button>
                    <button class="btn btn-sm btn-danger delete-btn" data-id="${meal.id}">Delete</button>
                  </td>
                </tr>
              `);
            });
            if ($.fn.DataTable.isDataTable('#mealsTable')) {
              $('#mealsTable').DataTable().destroy();
            }
            $('#mealsTable').DataTable({ pageLength: 25 });
          },
          error: function() {
            showToast('Error fetching meals', 'danger');
          }
        });
      }
      function showToast(message, type) {
        $('#toast .toast-body').text(message);
        $('#toast').removeClass('bg-success bg-danger text-white').addClass(type === 'success' ? 'bg-success' : 'bg-danger').addClass('text-white');
        $('#toast').toast({ delay: 3000 }).toast('show');
      }
    });
  </script>
</body>
</html>