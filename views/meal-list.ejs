<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meal List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-list"></i> Meal Plans by Date</h1>
      </div>
      <div class="card-body">
        <% Object.keys(mealsData).forEach(date => { %>
          <% 
            let totalProtein = 0, totalCarbs = 0, totalFats = 0;
            Object.values(mealsData[date].meals).forEach(meal => {
              totalProtein += meal.protein || 0;
              totalCarbs += meal.carbs || 0;
              totalFats += meal.fats || 0;
            });
            let typeRoute = mealsData[date].type === 'training' ? 'training-day' : 
                            mealsData[date].type === 'not-training' ? 'not-training-day' : 'check-in-day';
          %>
          <div class="border p-3 mb-3 rounded">
            <h3>Date: <%= date %></h3>
            <p><strong>Type:</strong> <%= mealsData[date].type %></p>
            <p><strong>User:</strong> <%= mealsData[date].user %></p>
            <p><strong>Total Protein:</strong> <%= totalProtein %>g</p>
            <p><strong>Total Carbs:</strong> <%= totalCarbs %>g</p>
            <p><strong>Total Fats:</strong> <%= totalFats %>g</p>
            <a href="/<%= typeRoute %>?date=<%= date %>" class="btn btn-primary">View Meals</a>
          </div>
        <% }); %>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>