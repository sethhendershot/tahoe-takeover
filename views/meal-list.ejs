<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meal List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-list"></i> Meal Plans by Date</h1>
      </div>
      <div class="card-body">
        <% Object.keys(mealsData).forEach(date => { %>
          <h2 class="mt-4">Date: <%= date %></h2>
          <p><strong>Type:</strong> <%= mealsData[date].type %></p>
          <p><strong>User:</strong> <%= mealsData[date].user %></p>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Meal #</th>
                <th>Protein (g)</th>
                <th>Carbs (g)</th>
                <th>Fats (g)</th>
              </tr>
            </thead>
            <tbody>
              <% Object.keys(mealsData[date].meals).forEach(mealNum => { %>
                <tr>
                  <td><%= mealNum %></td>
                  <td><%= mealsData[date].meals[mealNum].protein %></td>
                  <td><%= mealsData[date].meals[mealNum].carbs %></td>
                  <td><%= mealsData[date].meals[mealNum].fats %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% }); %>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>