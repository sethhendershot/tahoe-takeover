<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meal List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-list"></i> Meals by Date</h1>
      </div>
      <div class="card-body">
        <table id="mealsTable" class="table table-striped">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>User</th>
              <th>Total Protein (g)</th>
              <th>Total Carbs (g)</th>
              <th>Total Fats (g)</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% Object.keys(mealsData).forEach(date => { %>
              <% 
                let totalProtein = 0, totalCarbs = 0, totalFats = 0;
                Object.values(mealsData[date].meals).forEach(meal => {
                  totalProtein += meal.protein || 0;
                  totalCarbs += meal.carbs || 0;
                  totalFats += meal.fats || 0;
                });
                let typeRoute = mealsData[date].type === 'training' ? 'training-day' : 
                                mealsData[date].type === 'not-training' ? 'not-training-day' : 'check-in-day';
              %>
              <tr>
                <td><%= date %></td>
                <td><%= mealsData[date].type %></td>
                <td><%= mealsData[date].user %></td>
                <td><%= totalProtein %></td>
                <td><%= totalCarbs %></td>
                <td><%= totalFats %></td>
                <td><a href="/<%= typeRoute %>?date=<%= date %>" class="btn btn-primary btn-sm">View Meals</a></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
  <script>
    $(document).ready(function() {
      $('#mealsTable').DataTable();
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>