<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings - Prep Planner</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-cog"></i> Settings</h1>
        <p class="mb-0">Version 1.0.0</p>
      </div>
      <div class="card-body">
        <h3>Export Data</h3>
        <p>Download your data files:</p>
        <div class="row">
          <div class="col-md-4">
            <h5>JSON Files</h5>
            <ul class="list-group mb-3">
              <li class="list-group-item d-flex justify-content-between align-items-center">
                Meals Data
                <a href="/export/meals.json" class="btn btn-sm btn-primary" download>Download</a>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                Meal Options
                <a href="/export/meal-options.json" class="btn btn-sm btn-primary" download>Download</a>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                Meal Guide
                <a href="/export/meal-guide.json" class="btn btn-sm btn-primary" download>Download</a>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                Goals
                <a href="/export/goals.json" class="btn btn-sm btn-primary" download>Download</a>
              </li>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                Check-ins
                <a href="/export/check-ins.json" class="btn btn-sm btn-primary" download>Download</a>
              </li>
            </ul>
            <a href="/export/all-json.zip" class="btn btn-success" download>Export All JSON Files</a>
          </div>
          <div class="col-md-4">
            <h5>All Uploaded Pictures</h5>
            <p>Download all uploaded pictures as a ZIP file.</p>
            <a href="/export/pictures.zip" class="btn btn-success" download>Download All Pictures ZIP</a>
          </div>
          <div class="col-md-4">
            <h5>Selective Pictures Export</h5>
            <p>Select check-ins to export their pictures:</p>
            <form action="/export/selected-pictures" method="POST">
              <% Object.keys(checkInsData).sort().reverse().forEach(date => { %>
                <% if (checkInsData[date].pictures && checkInsData[date].pictures.length > 0) { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="dates" value="<%= date %>" id="check-<%= date %>">
                    <label class="form-check-label" for="check-<%= date %>">
                      <%= date %> <a href="#" data-bs-toggle="modal" data-bs-target="#modal-<%= date %>">(<%= checkInsData[date].pictures.length %> picture<%= checkInsData[date].pictures.length > 1 ? 's' : '' %>)</a>
                    </label>
                  </div>
                <% } %>
              <% }); %>
              <button type="submit" class="btn btn-warning mt-3">Download Selected Pictures ZIP</button>
            </form>
            <% Object.keys(checkInsData).sort().reverse().forEach(date => { %>
              <% if (checkInsData[date].pictures && checkInsData[date].pictures.length > 0) { %>
                <!-- Modal -->
                <div class="modal fade" id="modal-<%= date %>" tabindex="-1" aria-labelledby="modalLabel-<%= date %>" aria-hidden="true">
                  <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title" id="modalLabel-<%= date %>">Pictures for <%= date %></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <div class="modal-body">
                        <div class="row">
                          <% checkInsData[date].pictures.forEach(pic => { %>
                            <div class="col-md-6 mb-3">
                              <img src="/uploads/<%= pic %>" class="img-fluid" alt="Picture">
                            </div>
                          <% }); %>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              <% } %>
            <% }); %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>