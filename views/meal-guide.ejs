<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meal Guidance</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.css">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
  <%- include('menu') %>
  <div class="container mt-5">
    <div class="card">
      <div class="card-header">
        <h1><i class="fas fa-info-circle"></i> Meal Guidance</h1>
      </div>
      <div class="card-body">
        <ul class="nav nav-tabs" id="dayTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="non-training-tab" data-bs-toggle="tab" data-bs-target="#non-training" type="button" role="tab">Non-Training Day</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="training-tab" data-bs-toggle="tab" data-bs-target="#training" type="button" role="tab">Training Day</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="check-in-tab" data-bs-toggle="tab" data-bs-target="#check-in" type="button" role="tab">Check-in Day</button>
          </li>
        </ul>
        <div class="tab-content" id="dayTabsContent">
          <div class="tab-pane fade show active" id="non-training" role="tabpanel">
            <% if (isAdmin) { %>
              <button id="add-non-training" class="btn btn-primary mb-3">Add Meal</button>
            <% } %>
            <table id="non-training-table" class="display table table-striped">
              <thead>
                <tr>
                  <th>Meal</th>
                  <th>Protein (g)</th>
                  <th>Carb (g)</th>
                  <th>Fats (g)</th>
                  <th>Note</th>
                  <% if (isAdmin) { %>
                    <th>Actions</th>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% guide['non-training'].forEach(m => { %>
                  <tr>
                    <td><%= m.meal %></td>
                    <td><%= m.protein %></td>
                    <td><%= m.carb %></td>
                    <td><%= m.fats %></td>
                    <td><%= m.note %></td>
                    <% if (isAdmin) { %>
                      <td>
                        <button class="btn btn-sm btn-warning edit-btn" data-day="non-training" data-meal="<%= m.meal %>" data-protein="<%= m.protein %>" data-carb="<%= m.carb %>" data-fats="<%= m.fats %>" data-note="<%= m.note %>">Edit</button>
                        <button class="btn btn-sm btn-danger delete-btn" data-day="non-training" data-meal="<%= m.meal %>">Delete</button>
                      </td>
                    <% } %>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <div class="tab-pane fade" id="training" role="tabpanel">
            <% if (isAdmin) { %>
              <button id="add-training" class="btn btn-primary mb-3">Add Meal</button>
            <% } %>
            <table id="training-table" class="display table table-striped">
              <thead>
                <tr>
                  <th>Meal</th>
                  <th>Protein (g)</th>
                  <th>Carb (g)</th>
                  <th>Fats (g)</th>
                  <th>Note</th>
                  <% if (isAdmin) { %>
                    <th>Actions</th>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% guide['training'].forEach(m => { %>
                  <tr>
                    <td><%= m.meal %></td>
                    <td><%= m.protein %></td>
                    <td><%= m.carb %></td>
                    <td><%= m.fats %></td>
                    <td><%= m.note %></td>
                    <% if (isAdmin) { %>
                      <td>
                        <button class="btn btn-sm btn-warning edit-btn" data-day="training" data-meal="<%= m.meal %>" data-protein="<%= m.protein %>" data-carb="<%= m.carb %>" data-fats="<%= m.fats %>" data-note="<%= m.note %>">Edit</button>
                        <button class="btn btn-sm btn-danger delete-btn" data-day="training" data-meal="<%= m.meal %>">Delete</button>
                      </td>
                    <% } %>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <div class="tab-pane fade" id="check-in" role="tabpanel">
            <% if (isAdmin) { %>
              <button id="add-check-in" class="btn btn-primary mb-3">Add Meal</button>
            <% } %>
            <table id="check-in-table" class="display table table-striped">
              <thead>
                <tr>
                  <th>Meal</th>
                  <th>Protein (g)</th>
                  <th>Carb (g)</th>
                  <th>Fats (g)</th>
                  <th>Note</th>
                  <% if (isAdmin) { %>
                    <th>Actions</th>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% guide['check-in'].forEach(m => { %>
                  <tr>
                    <td><%= m.meal %></td>
                    <td><%= m.protein %></td>
                    <td><%= m.carb %></td>
                    <td><%= m.fats %></td>
                    <td><%= m.note %></td>
                    <% if (isAdmin) { %>
                      <td>
                        <button class="btn btn-sm btn-warning edit-btn" data-day="check-in" data-meal="<%= m.meal %>" data-protein="<%= m.protein %>" data-carb="<%= m.carb %>" data-fats="<%= m.fats %>" data-note="<%= m.note %>">Edit</button>
                        <button class="btn btn-sm btn-danger delete-btn" data-day="check-in" data-meal="<%= m.meal %>">Delete</button>
                      </td>
                    <% } %>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal fade" id="mealModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalTitle">Add Meal</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="mealForm">
            <input type="hidden" id="action" name="action">
            <input type="hidden" id="dayType" name="dayType">
            <input type="hidden" id="id" name="id">
            <div class="mb-3">
              <label for="meal" class="form-label">Meal Number</label>
              <input type="number" class="form-control" id="meal" name="meal" required>
            </div>
            <div class="mb-3">
              <label for="protein" class="form-label">Protein (g)</label>
              <input type="number" step="0.1" class="form-control" id="protein" name="protein" required>
            </div>
            <div class="mb-3">
              <label for="carb" class="form-label">Carb (g)</label>
              <input type="number" step="0.1" class="form-control" id="carb" name="carb" required>
            </div>
            <div class="mb-3">
              <label for="fats" class="form-label">Fats (g)</label>
              <input type="number" step="0.1" class="form-control" id="fats" name="fats" required>
            </div>
            <div class="mb-3">
              <label for="note" class="form-label">Note</label>
              <textarea class="form-control" id="note" name="note" rows="3"></textarea>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary" id="saveBtn">Save</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.js"></script>
  <script>
    $(document).ready(function() {
      $('#non-training-table').DataTable();
      $('#training-table').DataTable();
      $('#check-in-table').DataTable();

      <% if (isAdmin) { %>
        $('#add-non-training').click(() => openModal('add', 'non-training'));
        $('#add-training').click(() => openModal('add', 'training'));
        $('#add-check-in').click(() => openModal('add', 'check-in'));

        $(document).on('click', '.edit-btn', function() {
          const day = $(this).data('day');
          const meal = $(this).data('meal');
          openModal('edit', day, meal);
        });

        $(document).on('click', '.delete-btn', function() {
          const day = $(this).data('day');
          const meal = $(this).data('meal');
          if (confirm('Are you sure you want to delete this meal?')) {
            deleteMeal(day, meal);
          }
        });

        function openModal(action, dayType, mealId = null) {
          $('#action').val(action);
          $('#dayType').val(dayType);
          $('#id').val(mealId);
          if (action === 'edit') {
            const btn = $(`.edit-btn[data-day="${dayType}"][data-meal="${mealId}"]`);
            $('#meal').val(mealId);
            $('#protein').val(btn.data('protein'));
            $('#carb').val(btn.data('carb'));
            $('#fats').val(btn.data('fats'));
            $('#note').val(btn.data('note'));
          } else {
            $('#mealForm')[0].reset();
          }
          $('#modalTitle').text(action === 'add' ? 'Add Meal' : 'Edit Meal');
          $('#mealModal').modal('show');
        }

        $('#saveBtn').click(() => {
          const data = {
            action: $('#action').val(),
            dayType: $('#dayType').val(),
            meal: $('#meal').val(),
            protein: $('#protein').val(),
            carb: $('#carb').val(),
            fats: $('#fats').val(),
            note: $('#note').val(),
            id: $('#id').val()
          };
          fetch('/meal-guide', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          }).then(res => res.json()).then(response => {
            if (response.success) {
              $('#mealModal').modal('hide');
              const tableId = `${data.dayType}-table`;
              const table = $('#' + tableId).DataTable();
              const actions = '<button class="btn btn-sm btn-warning edit-btn" data-day="' + data.dayType + '" data-meal="' + data.meal + '" data-protein="' + data.protein + '" data-carb="' + data.carb + '" data-fats="' + data.fats + '" data-note="' + data.note + '">Edit</button> <button class="btn btn-sm btn-danger delete-btn" data-day="' + data.dayType + '" data-meal="' + data.meal + '">Delete</button>';
              const newRow = [data.meal, data.protein, data.carb, data.fats, data.note, actions];
              if (data.action === 'add') {
                table.row.add(newRow).draw();
              } else if (data.action === 'edit') {
                table.rows().every(function() {
                  if (this.data()[0] == data.id) {
                    this.data(newRow).draw();
                  }
                });
              }
            } else {
              alert('Error: ' + response.message);
            }
          });
        });

        function deleteMeal(dayType, mealId) {
          fetch('/meal-guide', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'delete', dayType, id: mealId })
          }).then(res => res.json()).then(data => {
            if (data.success) {
              const tableId = `${dayType}-table`;
              const table = $('#' + tableId).DataTable();
              table.rows().every(function() {
                if (this.data()[0] == mealId) {
                  this.remove().draw();
                }
              });
            } else {
              alert('Error: ' + data.message);
            }
          });
        }
      <% } %>
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>