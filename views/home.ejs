<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prep Planner</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
  <% if (user) { %>
    <%- include('menu') %>
  <% } %>
  <div class="container mt-5">
    <% if (user) { %>
      <div class="card">
        <div class="card-header">
          <h1><i class="fas fa-dashboard"></i> Prep Planning Dashboard</h1>
        </div>
        <div class="card-body text-center">
          <h3>Welcome, <%= user %>!</h3>
          <div class="mb-3">
            <h5 id="currentDateTime"></h5>
          </div>
          <% if (goals && goals.targetDate) { %>
            <div class="alert alert-info mb-3">
              <h6><i class="fas fa-calendar-alt"></i> Goal Countdown</h6>
              <p class="mb-1">Target Date: <strong id="targetDateDisplay"></strong></p>
              <p class="mb-0" id="countdown"></p>
            </div>
          <% } %>
          <p class="text-muted">Select your day type for meal planning:</p>
          <div class="row mt-4">
            <div class="col-md-6">
              <a href="/training-day" class="btn btn-primary btn-lg w-100 mb-3">
                <i class="fas fa-dumbbell"></i> Training Day
              </a>
            </div>
            <div class="col-md-6">
              <a href="/not-training-day" class="btn btn-secondary btn-lg w-100 mb-3">
                <i class="fas fa-couch"></i> Not Training Day
              </a>
            </div>
          </div>
          <div class="mt-3">
            <a href="/create-check-in" class="btn btn-info btn-lg w-100">
              <i class="fas fa-camera"></i> Add a Check In
            </a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function updateDateTime() {
      const now = new Date();
      const options = { 
        weekday: 'long', 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      };
      document.getElementById('currentDateTime').textContent = now.toLocaleDateString('en-US', options);
    }

    function updateCountdown() {
      <% if (goals && goals.targetDate) { %>
        // Parse date string as local date to avoid timezone issues
        const dateParts = '<%= goals.targetDate %>'.split('-');
        const targetDate = new Date(parseInt(dateParts[0]), parseInt(dateParts[1]) - 1, parseInt(dateParts[2]));
        
        // Display the target date correctly
        document.getElementById('targetDateDisplay').textContent = targetDate.toLocaleDateString();
        
        const now = new Date();
        const timeDiff = targetDate - now;
        
        if (timeDiff > 0) {
          const days = Math.ceil(timeDiff / (1000 * 60 * 60 * 24));
          document.getElementById('countdown').textContent = `${days} days remaining until your goal!`;
        } else {
          document.getElementById('countdown').textContent = 'Goal date has passed!';
        }
      <% } %>
    }

    // Update immediately
    updateDateTime();
    updateCountdown();

    // Update every second
    setInterval(updateDateTime, 1000);
    
    // Update countdown every minute
    setInterval(updateCountdown, 60000);
  </script>
</body>
</html>