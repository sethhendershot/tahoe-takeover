<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Meal Planning App</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <% if (user) { %>
    <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Prep Planner</a>
        <div class="navbar-nav ms-auto">
          <a class="nav-link" href="/meals">View All Meals</a>
          <form class="d-inline" action="/logout" method="POST">
            <button class="btn btn-link nav-link" type="submit">Logout</button>
          </form>
        </div>
      </div>
    </nav>
  <% } %>
  <div class="container mt-5">
    <% if (user) { %>
      <div class="card">
        <div class="card-body">
          <h1 class="card-title">Welcome, <%= user %>!</h1>
          <p class="card-text">Select your day type for meal planning:</p>
          <a href="/training-day" class="btn me-2 mb-2" style="background-color: #6f42c1; color: white; border: none;">Training Day</a>
          <a href="/not-training-day" class="btn me-2 mb-2" style="background-color: #e83e8c; color: white; border: none;">Not Training Day</a>
          <a href="/check-in-day" class="btn mb-2" style="background-color: #6f42c1; color: white; border: none;">Check In Day</a>
          
        </div>
      </div>
    <% } else { %>
      <div class="card">
        <div class="card-header">
          <h1>Please log in</h1>
        </div>
        <div class="card-body">
          <form action="/login" method="POST">
            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input type="text" class="form-control" id="username" name="username" placeholder="Username" required>
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
            </div>
            <button type="submit" class="btn btn-primary">Login</button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>