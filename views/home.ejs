<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prep Planner</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-light">
  <% if (user) { %>
    <%- include('menu') %>
  <% } %>
  <div class="container mt-5">
    <% if (user) { %>
      <div class="card">
        <div class="card-header">
          <h1><i class="fas fa-dashboard"></i> Prep Planning Dashboard</h1>
        </div>
        <div class="card-body text-center">
          <h3>Welcome, <%= user %>!</h3>
          <p class="text-muted">Select your day type for meal planning:</p>
          <div class="row mt-4">
            <div class="col-md-6">
              <a href="/training-day" class="btn btn-primary btn-lg w-100 mb-3">
                <i class="fas fa-dumbbell"></i> Training Day
              </a>
            </div>
            <div class="col-md-6">
              <a href="/not-training-day" class="btn btn-secondary btn-lg w-100 mb-3">
                <i class="fas fa-couch"></i> Not Training Day
              </a>
            </div>
          </div>
          <div class="mt-3">
            <a href="/create-check-in" class="btn btn-info btn-lg w-100">
              <i class="fas fa-camera"></i> Add a Check In
            </a>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="card">
        <div class="card-header">
          <h1>Please log in</h1>
        </div>
        <div class="card-body">
          <form action="/login" method="POST">
            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input type="text" class="form-control" id="username" name="username" placeholder="Username" required>
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <input type="password" class="form-control" id="password" name="password" placeholder="Password" required>
            </div>
            <button type="submit" class="btn btn-primary">Login</button>
          </form>
        </div>
      </div>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>